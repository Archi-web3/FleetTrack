{
    "version": 2,
    "builds": [
        {
            "src": "index.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "index.js"
        }
    ],
    "env": {
        "MONGODB_URI": "mongodb+srv://admin:admin@cluster0.example.mongodb.net/test",
        "JWT_SECRET": "secret"
    }
}